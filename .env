# TIS Gateway — Environment Variables
# Salin file ini ke .env lalu sesuaikan nilai per environment.
# File ini TIDAK boleh di-commit ke git (sudah ada di .gitignore).

# ── Koneksi ke TIS (CCU/MON Unit) ─────────────────────────────────
TIS_HOST=192.168.1.1
TIS_PORT=262       # default 262, ubah jika perlu
LOCAL_PORT=263     # default 263

# ── Output file ────────────────────────────────────────────────────
OUTPUT_DIR=./output

# ── Cloud API (Laravel tis_api_laravel) ───────────────────────────
CLOUD_API_URL=http://127.0.0.1:8000
TIS_API_KEY=tiomuhamadnur

# ── Logging ────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
