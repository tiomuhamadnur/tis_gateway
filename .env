# TIS Gateway — Environment Variables
# Salin file ini ke .env lalu sesuaikan nilai per environment.
# File ini TIDAK boleh di-commit ke git (sudah ada di .gitignore).

# ── Koneksi ke TIS (CCU/MON Unit) ─────────────────────────────────
TIS_HOST=192.168.1.1
TIS_PORT=262       # default 262, ubah jika perlu
LOCAL_PORT=263     # default 263

# ── Output file ────────────────────────────────────────────────────
OUTPUT_DIR=./output

# ── Cloud API (Laravel tis_api_laravel) ───────────────────────────
CLOUD_API_URL=https://tis-gateway.tideupindustries.com
TIS_API_KEY=tiomuhamadnur
CLOUD_ENABLED=true

# Status LED / GPIO
# Default off supaya aman bila deploy ke hardware lain.
LED_ENABLED=false
GPIO_BACKEND=sysfs
GPIO_ACTIVE_LOW=false
# Default Orange Pi Zero LTS:
#   red    -> PA3  (GPIO3)
#   yellow -> PA6  (GPIO6)
#   green  -> PA7  (GPIO7)
LED_RED_PIN=3
LED_YELLOW_PIN=6
LED_GREEN_PIN=7
LED_BLINK_INTERVAL_SEC=0.5
LED_SUCCESS_PULSE_SEC=1.5
LED_ERROR_HOLD_SEC=2.5

# ── Logging ────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# Rotasi file log — hapus otomatis log lebih dari N hari
LOG_RETENTION_DAYS=30

# Ukuran maks file log sebelum rotate (fallback, bytes). 10 MB default.
LOG_MAX_BYTES=10485760 #10MB

# Jumlah backup file log (size-based rotation fallback)
LOG_BACKUP_COUNT=5

# ── Daemon / Loop ──────────────────────────────────
# Interval minimal antar download dari TIS (menit).
# Jika daemon berjalan 24/7, ia hanya akan request data TIS
# setiap N menit untuk menghindari banjir data.
# Nilai harus LEBIH BESAR dari durasi satu siklus lengkap
# (download + generate + upload). Default=4320 (3 hari).
TIS_INTERVAL_READ_DATA=4320

# Jumlah maksimum session folder di output/raw/.
# Jika terlampaui, folder tertua akan dihapus (data loss).
# Data tetap aman jika upload sukses karena sudah pindah
# ke sent-cloud/. Default=50.
MAX_SESSION_RAW=50

# Jumlah maksimum session folder di output/sent-cloud/.
# Jika terlampaui, folder tertua akan dihapus (data loss).
# Default=200.
MAX_SESSION_SENT=200

# Interval loop utama daemon (detik).
# Setiap N detik, daemon akan: ping TIS → retry pending →
# cek interval → download → generate → upload → prune.
# Default=10.
LOOP_INTERVAL_SEC=10

# Berapa kali daemon mencoba upload ulang session yang gagal.
# Session tetap di raw/ jika semua percobaan gagal,
# dan akan dicoba lagi di iterasi loop berikutnya.
# Default=5.
UPLOAD_MAX_RETRIES=5
