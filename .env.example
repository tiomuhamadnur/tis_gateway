# TIS Gateway - Environment Variables
# Copy to `.env` and adjust per environment.

# -----------------------------------------------------------------------------
# TIS connection (CCU/MON unit)
# -----------------------------------------------------------------------------
TIS_HOST=192.168.1.1
TIS_PORT=262
LOCAL_PORT=263

# -----------------------------------------------------------------------------
# Output file
# -----------------------------------------------------------------------------
OUTPUT_DIR=./output

# -----------------------------------------------------------------------------
# Cloud API (Laravel tis_api_laravel)
# -----------------------------------------------------------------------------
CLOUD_API_URL=https://tis-gateway.tideupindustries.com
TIS_API_KEY=tiomuhamadnur
CLOUD_ENABLED=true

# -----------------------------------------------------------------------------
# Status LED / GPIO
# -----------------------------------------------------------------------------
# LED default dimatikan supaya aman untuk hardware lain.
LED_ENABLED=false

# Backend GPIO:
#   mock  = log-only, cocok untuk development di PC/laptop
#   sysfs = akses /sys/class/gpio di Linux/Orange Pi
GPIO_BACKEND=sysfs

# true jika wiring LED aktif-rendah.
GPIO_ACTIVE_LOW=false

# Mapping pin GPIO. Isi sesuai board yang dipakai.
# Default Orange Pi Zero LTS:
#   red    -> PA3  (GPIO3)
#   yellow -> PA6  (GPIO6)
#   green  -> PA7  (GPIO7)
LED_RED_PIN=3
LED_YELLOW_PIN=6
LED_GREEN_PIN=7

# Timing status visual (detik).
LED_BLINK_INTERVAL_SEC=0.5
LED_SUCCESS_PULSE_SEC=1.5
LED_ERROR_HOLD_SEC=2.5

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG
LOG_RETENTION_DAYS=30
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Daemon / Loop
# -----------------------------------------------------------------------------
TIS_INTERVAL_READ_DATA=4320
MAX_SESSION_RAW=50
MAX_SESSION_SENT=200
LOOP_INTERVAL_SEC=10
UPLOAD_MAX_RETRIES=5
