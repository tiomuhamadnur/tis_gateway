{
  "permissions": {
    "allow": [
      "PowerShell(try { $r = Invoke-WebRequest -Uri \"http://localhost:8000/login\" -UseBasicParsing -TimeoutSec 10 -MaximumRedirection 1; \"Status: $\\($r.StatusCode\\), Length: $\\($r.Content.Length\\)\" } catch { \"Error: $\\($_.Exception.Message\\)\" })"
    ]
  }
}
